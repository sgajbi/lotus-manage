{
  "contract_id": "lotus-manage:observability-monitoring:v1",
  "contract_version": "1.0.0",
  "service": "lotus-manage",
  "owner_repository": "lotus-manage",
  "status": "active",
  "purpose": "Govern the implemented monitoring surface for discretionary portfolio management APIs without exposing portfolio, client, request, idempotency, instrument, or raw upstream identifiers.",
  "no_sensitive_telemetry_policy": {
    "forbidden_label_values": [
      "portfolio_id",
      "account_id",
      "client_id",
      "instrument_id",
      "request_hash",
      "idempotency_key",
      "correlation_id",
      "run_id",
      "actor_id",
      "raw_error"
    ],
    "label_cardinality_posture": "bounded_allowlist_only"
  },
  "metrics": [
    {
      "name": "lotus_manage_action_register_supportability_total",
      "type": "counter",
      "description": "Counts supportability summary observations for the portfolio action register surface.",
      "labels": {
        "surface": ["rebalance/supportability/summary", "unknown_surface"],
        "supportability_state": [
          "ready",
          "stale",
          "degraded",
          "empty",
          "error",
          "permission_blocked",
          "unsupported"
        ],
        "reason": [
          "supportability_summary_ready",
          "supportability_summary_empty",
          "supportability_summary_stale",
          "supportability_summary_degraded",
          "supportability_summary_error",
          "permission_blocked",
          "unsupported_surface"
        ],
        "freshness_bucket": ["current", "same_day", "stale", "unknown"]
      },
      "source": "src.api.observability.record_action_register_supportability"
    },
    {
      "name": "lotus_manage_core_resolver_total",
      "type": "counter",
      "description": "Counts stateful lotus-core resolver outcomes for DPM execution-context sourcing.",
      "labels": {
        "operation": ["dpm_execution_context"],
        "outcome": ["success", "unavailable", "incomplete", "error"],
        "supportability_state": ["ready", "degraded", "incomplete", "unavailable", "unknown"],
        "reason": [
          "ready",
          "degraded",
          "resolver_unavailable",
          "context_incomplete",
          "invalid_response",
          "unexpected_error"
        ]
      },
      "source": "src.api.observability.record_core_resolver_call"
    },
    {
      "name": "lotus_manage_execution_total",
      "type": "counter",
      "description": "Counts DPM simulate, analyze, and async analyze execution outcomes.",
      "labels": {
        "operation": ["simulate", "analyze", "analyze_async"],
        "input_mode": ["stateless", "stateful", "unknown"],
        "outcome": [
          "success",
          "partial_failure",
          "blocked",
          "replayed",
          "accepted",
          "conflict",
          "error"
        ],
        "result_status": [
          "ready",
          "pending_review",
          "blocked",
          "accepted",
          "partial_success",
          "failed",
          "unknown"
        ]
      },
      "source": "src.api.observability.record_execution_call"
    },
    {
      "name": "lotus_manage_async_operation_total",
      "type": "counter",
      "description": "Counts async operation submission and execution lifecycle outcomes.",
      "labels": {
        "event": ["submit", "execute"],
        "execution_mode": ["inline", "accept_only", "manual", "unknown"],
        "outcome": [
          "accepted",
          "succeeded",
          "failed",
          "conflict",
          "not_found",
          "not_executable",
          "disabled"
        ]
      },
      "source": "src.api.observability.record_async_operation"
    },
    {
      "name": "lotus_manage_policy_pack_resolution_total",
      "type": "counter",
      "description": "Counts policy-pack resolution posture for execution and diagnostic policy surfaces.",
      "labels": {
        "surface": ["simulate", "analyze", "analyze_async", "api"],
        "enabled": ["true", "false"],
        "source": ["disabled", "request", "tenant_default", "global_default", "none", "unknown"],
        "selected": ["true", "false"]
      },
      "source": "src.api.observability.record_policy_pack_resolution"
    },
    {
      "name": "lotus_manage_workflow_decision_total",
      "type": "counter",
      "description": "Counts workflow action outcomes for discretionary mandate review gates.",
      "labels": {
        "surface": ["run", "trace", "retry"],
        "action": ["approve", "reject", "request_changes", "unknown"],
        "outcome": ["success", "not_found", "disabled", "conflict", "error"]
      },
      "source": "src.api.observability.record_workflow_decision"
    },
    {
      "name": "lotus_manage_wave_supportability_total",
      "type": "counter",
      "description": "Counts product-safe rebalance wave supportability endpoint outcomes.",
      "labels": {
        "surface": ["rebalance/waves/supportability"],
        "supportability_state": ["ready", "degraded", "blocked", "not_found"],
        "reason": [
          "wave_supportability_ready",
          "wave_degraded_items",
          "wave_blocked_items",
          "wave_not_found",
          "wave_supportability_error"
        ]
      },
      "source": "src.api.observability.record_wave_supportability"
    },
    {
      "name": "lotus_manage_outcome_review_supportability_total",
      "type": "counter",
      "description": "Counts product-safe post-trade outcome-review API and supportability outcomes.",
      "labels": {
        "surface": [
          "rebalance/outcome-reviews/create",
          "rebalance/outcome-reviews/refresh-sources",
          "rebalance/outcome-reviews/supportability"
        ],
        "supportability_state": [
          "ready",
          "pending_review",
          "breached",
          "degraded",
          "blocked",
          "not_supported",
          "not_found",
          "error"
        ],
        "reason": [
          "outcome_review_ready",
          "outcome_review_pending_review",
          "outcome_review_breached",
          "outcome_review_degraded",
          "outcome_review_blocked",
          "outcome_review_not_supported",
          "outcome_review_source_refreshed",
          "outcome_review_not_found",
          "outcome_review_error"
        ]
      },
      "source": "src.api.observability.record_outcome_review_supportability"
    }
  ],
  "dashboards": [
    {
      "dashboard_id": "lotus-manage-dpm-operational-health",
      "audience": ["operations", "engineering", "platform-governance"],
      "panels": [
        {
          "panel_id": "action-register-supportability-by-state",
          "title": "Portfolio Action Register Supportability",
          "metric": "lotus_manage_action_register_supportability_total",
          "query": "sum by (supportability_state, reason, freshness_bucket) (rate(lotus_manage_action_register_supportability_total[5m]))",
          "use_when": "Monitor supportability summary readiness and freshness for action-register operational evidence."
        },
        {
          "panel_id": "core-resolver-outcomes",
          "title": "Stateful Core Resolver Outcomes",
          "metric": "lotus_manage_core_resolver_total",
          "query": "sum by (outcome, supportability_state, reason) (rate(lotus_manage_core_resolver_total[5m]))",
          "use_when": "Monitor stateful resolver readiness after the governed lotus-core DPM execution-context contract is available."
        },
        {
          "panel_id": "dpm-execution-outcomes",
          "title": "DPM Execution Outcomes",
          "metric": "lotus_manage_execution_total",
          "query": "sum by (operation, input_mode, outcome, result_status) (rate(lotus_manage_execution_total[5m]))",
          "use_when": "Monitor simulate, analyze, and async analyze behavior across stateless and future stateful modes."
        },
        {
          "panel_id": "async-operation-lifecycle",
          "title": "Async Operation Lifecycle",
          "metric": "lotus_manage_async_operation_total",
          "query": "sum by (event, execution_mode, outcome) (rate(lotus_manage_async_operation_total[5m]))",
          "use_when": "Monitor async submission and execution health, including conflicts and failed executions."
        },
        {
          "panel_id": "policy-pack-resolution",
          "title": "Policy-Pack Resolution",
          "metric": "lotus_manage_policy_pack_resolution_total",
          "query": "sum by (surface, enabled, source, selected) (rate(lotus_manage_policy_pack_resolution_total[5m]))",
          "use_when": "Monitor whether execution and diagnostic surfaces are using request, tenant, global, or disabled policy-pack posture."
        },
        {
          "panel_id": "workflow-decision-outcomes",
          "title": "Workflow Decision Outcomes",
          "metric": "lotus_manage_workflow_decision_total",
          "query": "sum by (surface, action, outcome) (rate(lotus_manage_workflow_decision_total[5m]))",
          "use_when": "Monitor discretionary mandate review-gate action outcomes without actor, run, or portfolio identifiers."
        },
        {
          "panel_id": "outcome-review-supportability",
          "title": "Post-Trade Outcome Review Supportability",
          "metric": "lotus_manage_outcome_review_supportability_total",
          "query": "sum by (surface, supportability_state, reason) (rate(lotus_manage_outcome_review_supportability_total[5m]))",
          "use_when": "Monitor RFC-0042 outcome-review create, source-refresh, and supportability outcomes without portfolio, run, proof-pack, wave, or actor identifiers."
        }
      ]
    }
  ],
  "alerts": [
    {
      "alert_id": "lotus-manage-action-register-supportability-errors",
      "severity": "warning",
      "metric": "lotus_manage_action_register_supportability_total",
      "expression": "sum(rate(lotus_manage_action_register_supportability_total{supportability_state=\"error\"}[5m])) > 0",
      "for": "10m",
      "description": "Action-register supportability summary is returning error state.",
      "runbook": "wiki/Operations-Runbook.md#rfc-0108-action-register-supportability"
    },
    {
      "alert_id": "lotus-manage-core-resolver-unavailable",
      "severity": "critical",
      "metric": "lotus_manage_core_resolver_total",
      "expression": "sum(rate(lotus_manage_core_resolver_total{outcome=\"unavailable\"}[5m])) > 0",
      "for": "5m",
      "description": "Stateful DPM execution context cannot be resolved from lotus-core.",
      "runbook": "wiki/Operations-Runbook.md#rfc-0108-action-register-supportability"
    },
    {
      "alert_id": "lotus-manage-core-resolver-incomplete-context",
      "severity": "warning",
      "metric": "lotus_manage_core_resolver_total",
      "expression": "sum(rate(lotus_manage_core_resolver_total{outcome=\"incomplete\"}[15m])) > 0",
      "for": "15m",
      "description": "lotus-core returned an incomplete or invalid DPM execution context.",
      "runbook": "wiki/Operations-Runbook.md#rfc-0108-action-register-supportability"
    },
    {
      "alert_id": "lotus-manage-execution-errors",
      "severity": "critical",
      "metric": "lotus_manage_execution_total",
      "expression": "sum(rate(lotus_manage_execution_total{outcome=\"error\"}[5m])) > 0",
      "for": "5m",
      "description": "DPM execution requests are failing before producing a governed result.",
      "runbook": "wiki/Operations-Runbook.md#rfc-0108-action-register-supportability"
    },
    {
      "alert_id": "lotus-manage-async-failures",
      "severity": "warning",
      "metric": "lotus_manage_async_operation_total",
      "expression": "sum(rate(lotus_manage_async_operation_total{outcome=\"failed\"}[10m])) > 0",
      "for": "10m",
      "description": "Async operation execution is failing.",
      "runbook": "wiki/Operations-Runbook.md#rfc-0108-action-register-supportability"
    },
    {
      "alert_id": "lotus-manage-policy-pack-resolution-disabled",
      "severity": "info",
      "metric": "lotus_manage_policy_pack_resolution_total",
      "expression": "sum(rate(lotus_manage_policy_pack_resolution_total{enabled=\"false\"}[30m])) > 0",
      "for": "30m",
      "description": "Policy-pack resolution is disabled for observed execution or diagnostic surfaces.",
      "runbook": "wiki/Operations-Runbook.md#rfc-0108-action-register-supportability"
    },
    {
      "alert_id": "lotus-manage-workflow-decision-conflicts",
      "severity": "warning",
      "metric": "lotus_manage_workflow_decision_total",
      "expression": "sum(rate(lotus_manage_workflow_decision_total{outcome=\"conflict\"}[10m])) > 0",
      "for": "10m",
      "description": "Workflow action requests are conflicting with current discretionary mandate review state.",
      "runbook": "wiki/Operations-Runbook.md#rfc-0108-action-register-supportability"
    },
    {
      "alert_id": "lotus-manage-outcome-review-blocked",
      "severity": "warning",
      "metric": "lotus_manage_outcome_review_supportability_total",
      "expression": "sum(rate(lotus_manage_outcome_review_supportability_total{supportability_state=\"blocked\"}[15m])) > 0",
      "for": "15m",
      "description": "Post-trade outcome reviews are blocked by missing or invalid source evidence.",
      "runbook": "wiki/Operations-Runbook.md#rfc-0042-outcome-review-supportability"
    }
  ],
  "evidence": {
    "local_validation": [
      "python scripts/validate_observability_contracts.py",
      "python -m pytest tests/unit/test_observability_contracts.py"
    ],
    "remote_lane": "Remote Feature Lane"
  }
}
